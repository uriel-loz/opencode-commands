{
  "plan": {
    "permission": {
      "skill": {
        "*": "allow",
        "sdd-*": "deny"
      }
    }
  },
  "build": {
    "permission": {
      "skill": {
        "*": "allow",
        "sdd-*": "deny"
      },
      "bash": {
        "*": "ask",
        "git status*": "allow",
        "git log*": "allow",
        "git diff*": "allow",
        "git add*": "allow",
        "git commit*": "ask",
        "git push*": "ask"
      }
    }
  },
  "apply": {
    "description": "Applies previously reviewed and approved code change proposals to the codebase. Invoke only after a review phase has concluded and changes are ready to be implemented.",
    "mode": "subagent",
    "model": "opencode-go/minimax-m2.7",
    "permission": {
      "bash": "ask",
      "edit": "allow",
      "glob": "allow",
      "grep": "allow",
      "lsp": "deny",
      "read": "allow",
      "task": "deny",
      "todowrite": "deny",
      "webfetch": "deny",
      "websearch": "deny",
      "write": "allow"
    },
    "temperature": 0.1,
    "top_p": 0.9
  },
  "review": {
    "description": "Sanity-check a proposed fix before implementation. Validate likely root cause, confirm the smallest safe change, and flag only meaningful risks without expanding scope.",
    "mode": "subagent",
    "model": "github-copilot/gpt-5.4",
    "permission": {
      "bash": "deny",
      "edit": "deny",
      "glob": "allow",
      "grep": "allow",
      "lsp": "deny",
      "read": "allow",
      "skill": "deny",
      "task": "deny",
      "todowrite": "deny",
      "webfetch": "deny",
      "websearch": "deny",
      "write": "deny"
    },
    "temperature": 0.1,
    "top_p": 0.9
  },
  "task": {
    "description": "Turn validated analysis into the smallest useful implementation task list. Use after root cause is understood and concise execution-ready steps are needed without expanding scope.",
    "mode": "subagent",
    "model": "github-copilot/claude-sonnet-4.6",
    "permission": {
      "bash": "deny",
      "edit": "deny",
      "glob": "allow",
      "grep": "allow",
      "read": "allow",
      "write": "deny"
    },
    "temperature": 0.3,
    "top_p": 0.9
  },
  "verify": {
    "description": "Verifies that applied code matches the reviewed plan and directly corrects any discrepancies in the code. Invoke after changes have been applied by @apply.",
    "mode": "subagent",
    "model": "github-copilot/gpt-5.3-codex",
    "permission": {
      "bash": "ask",
      "edit": "allow",
      "glob": "allow",
      "grep": "allow",
      "lsp": "deny",
      "read": "allow",
      "skill": "deny",
      "task": "deny",
      "todowrite": "deny",
      "webfetch": "deny",
      "websearch": "deny",
      "write": "allow"
    },
    "steps": 15,
    "temperature": 0.1,
    "top_p": 0.9
  }
}
